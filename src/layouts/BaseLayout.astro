---
import "../styles/global.css";

type Props = {
  title?: string;
  lang?: "en" | "ja";
  homeHref?: string;
  enHref?: string;
  jaHref?: string;
};

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base}${p.replace(/^\/+/, "")}`;

const props = Astro.props as Props;

const title = props.title ?? "Portfolio";
const lang = props.lang ?? "en";

const homeHref = props.homeHref ?? withBase(lang === "ja" ? "ja/" : "en/");
const enHref = props.enHref ?? withBase("en/");
const jaHref = props.jaHref ?? withBase("ja/");

const t = (en: string, ja: string) => (lang === "ja" ? ja : en);

// Title-block footer values (auto date so it never goes stale)
const now = new Date();
const drawnDate = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={t(
      "Cooper Lender — Stanford EE student. ADC research, analog front-ends, embedded systems.",
      "Cooper Lender — スタンフォード大学EE専攻。ADC研究、アナログ回路、組込みシステム。"
    )} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <header class="site-header">
        <a class="site-name" href={homeHref}>
          Cooper Lender
          <span class="site-sub">/ {t("EE Portfolio", "EEポートフォリオ")}</span>
        </a>
        <nav class="lang-switch" aria-label="Language switch">
          <a class={lang === "en" ? "active" : ""} href={enHref}>EN</a>
          <a class={lang === "ja" ? "active" : ""} href={jaHref}>日本語</a>
        </nav>
      </header>

      <slot />
    </main>

    <footer class="title-block">
      <div class="tb-grid">
        <div class="tb-cell">
          <span class="tb-label">{t("Title", "件名")}</span>
          <span class="tb-value">{t("Portfolio — Cooper Lender", "ポートフォリオ — Cooper Lender")}</span>
        </div>
        <div class="tb-cell">
          <span class="tb-label">{t("Engineer", "担当")}</span>
          <span class="tb-value">C.L.</span>
        </div>
        <div class="tb-cell">
          <span class="tb-label">{t("Date", "日付")}</span>
          <span class="tb-value">{drawnDate}</span>
        </div>
        <div class="tb-cell">
          <span class="tb-label">Rev</span>
          <span class="tb-value">2.0</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Scroll reveal for elements tagged .reveal (respects reduced motion)
      (() => {
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const els = document.querySelectorAll(".reveal");
        if (reduced || !("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px -40px 0px" }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
