---
import AdcDemo from "./AdcDemo.astro";
import SkillsSection from "./SkillsSection.astro";
import { content, profile } from "../data/content.js";

const { lang = "en" } = Astro.props;
const c = lang === "ja" ? content.ja : content.en;
const resumeHref = `${import.meta.env.BASE_URL}${profile.resumePath}`;
---

<section class="hero">
  <p class="hero-kicker">// {c.hero.kicker}</p>
  <h1>{profile.name}</h1>
  <p class="sub">{c.hero.sub}</p>

  <div class="hero-spec">
    {c.hero.spec.map((s) => <span>{s}</span>)}
  </div>

  <div class="btn-row">
    <a class="btn primary" href={`mailto:${profile.email}`}>{c.hero.buttons.email}</a>
    <a class="btn" href={profile.github} target="_blank" rel="noopener">GitHub</a>
    <a class="btn" href={profile.linkedin} target="_blank" rel="noopener">LinkedIn</a>
    <a class="btn" href={resumeHref} target="_blank" rel="noopener">{c.hero.buttons.resume}</a>
  </div>

  <p class="note">{c.hero.note}</p>

  <!-- hand-drawn EKG trace, animates on load -->
  <svg class="hero-trace" viewBox="0 0 800 56" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,28 L90,28 L104,24 L118,28 L136,28 L144,34 L156,6 L168,46 L178,22 L190,28
             L290,28 L304,24 L318,28 L336,28 L344,34 L356,6 L368,46 L378,22 L390,28
             L490,28 L504,24 L518,28 L536,28 L544,34 L556,6 L568,46 L578,22 L590,28
             L690,28 L704,24 L718,28 L736,28 L744,34 L756,6 L768,46 L778,22 L790,28 L800,28" />
  </svg>
</section>

<section class="section reveal" id="research">
  <div class="section-head">
    <span class="fig-no">{c.research.figNo}</span>
    <h2>{c.research.title}</h2>
  </div>
  <p class="section-lede">{c.research.lede}</p>
  <p>{c.research.body}</p>
  <p class="muted" style="margin-top:12px; font-size:0.93rem;">{c.research.demoNote}</p>
  <AdcDemo lang={lang} />
</section>

<section class="section reveal" id="projects">
  <div class="section-head">
    <span class="fig-no">{c.projects.figNo}</span>
    <h2>{c.projects.title}</h2>
  </div>
  <p class="section-lede">{c.projects.lede}</p>

  <div class="project-list">
    {c.projects.items.map((p, i) => (
      <a class="project-entry" href={p.href}>
        <span class="project-num">P-{String(i + 1).padStart(2, "0")}</span>
        <div class="project-content">
          <h3 class="project-title">{p.title}</h3>
          <p class="project-desc muted">{p.desc}</p>
          <div class="tags">
            {p.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
        <span class="project-arrow">-&gt;</span>
      </a>
    ))}
  </div>
</section>

<div class="reveal">
  <SkillsSection lang={lang} figNo={c.skills.figNo} title={c.skills.title} />
</div>

<section class="section reveal" id="about">
  <div class="section-head">
    <span class="fig-no">{c.about.figNo}</span>
    <h2>{c.about.title}</h2>
  </div>
  <div class="about-cols">
    {c.about.items.map((item) => (
      <div class="about-item">
        <span class="anno">{item.label}</span>
        <p>{item.text}</p>
      </div>
    ))}
  </div>
</section>

<section class="section contact reveal" id="contact">
  <div class="section-head">
    <span class="fig-no">{c.contact.figNo}</span>
    <h2>{c.contact.title}</h2>
  </div>
  <p class="muted">{c.contact.lede}</p>
  <div class="contact-row">
    <a class="btn primary" href={`mailto:${profile.email}`}>{c.contact.buttons.email}</a>
    <a class="btn" href={profile.github} target="_blank" rel="noopener">GitHub</a>
    <a class="btn" href={profile.linkedin} target="_blank" rel="noopener">LinkedIn</a>
    <a class="btn" href={resumeHref} target="_blank" rel="noopener">{c.contact.buttons.resume}</a>
  </div>
</section>
