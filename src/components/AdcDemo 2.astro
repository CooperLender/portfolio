---
// Interactive ADC model: analog sine → sampler → quantizer.
// Written for a viewer who doesn't know what an ADC is: plain-language
// intro, friendly slider labels, and a power bar (ideal flash ADC,
// 2^N−1 comparators × sample rate) showing the resolution/power tradeoff.
const { lang = "en" } = Astro.props;
const t = (en: string, ja: string) => (lang === "ja" ? ja : en);

const labels = {
  panelTitle: t("ADC-01 — Turning Analog into Digital", "ADC-01 — アナログからデジタルへ"),
  running: t("RUNNING", "動作中"),
  paused: t("PAUSED", "停止中"),
  intro: t(
    "An ADC (analog-to-digital converter) is how electronics read the real world: it measures a smooth signal at regular moments and stores each measurement as a number. Orange is the real signal — blue is what the chip records.",
    "ADC（アナログ・デジタル変換器）は、電子機器が現実世界を読み取る仕組みです。滑らかな信号を一定間隔で測定し、数値として記録します。オレンジが実際の信号、青がチップに記録されるデータです。"
  ),
  fs: t("Sample rate — how often it measures", "サンプリング速度 — 測る頻度"),
  bits: t("Resolution — how finely it measures", "分解能 — 測る細かさ"),
  legend: {
    analog: t("real signal", "実際の信号"),
    samples: t("measurements", "測定点"),
    digital: t("digital output", "デジタル出力"),
  },
  alias: t("too slow — signal misread (aliasing)", "速度不足 — 信号を誤読（エイリアシング）"),
  power: t("Power — ideal flash ADC", "消費電力 — 理想フラッシュADC"),
  powerHint: t(
    "A flash ADC needs 2^N−1 comparators, each working at the sample rate — accuracy and speed cost power.",
    "フラッシュADCには 2^N−1 個のコンパレータが必要で、それぞれがサンプリング速度で動作します。精度と速度は電力とのトレードオフです。"
  ),
  comparators: t("comparators", "コンパレータ"),
  comparator: t("comparator", "コンパレータ"),
  powerUnit: t("× min power", "倍（最小比）"),
  pause: t("Pause", "停止"),
  run: t("Run", "再生"),
};
---

<div class="adc-panel card" data-adc data-run-label={labels.run} data-paused-label={labels.paused} data-comp-label={labels.comparators} data-comp-singular={labels.comparator} data-power-unit={labels.powerUnit}>
  <div class="adc-head">
    <span class="adc-title">{labels.panelTitle}</span>
    <span class="adc-status">
      <span class="adc-led" data-led></span>
      <span data-status>{labels.running}</span>
    </span>
  </div>

  <p class="adc-intro">{labels.intro}</p>

  <canvas class="adc-canvas" data-canvas height="240" aria-label={labels.panelTitle}></canvas>

  <div class="adc-legend">
    <span><i class="sw sw-analog"></i>{labels.legend.analog}</span>
    <span><i class="sw sw-sample"></i>{labels.legend.samples}</span>
    <span><i class="sw sw-digital"></i>{labels.legend.digital}</span>
    <span class="adc-alias" data-alias hidden>⚠ {labels.alias}</span>
  </div>

  <div class="adc-controls">
    <label class="adc-ctl">
      <span class="adc-ctl-label"><span>{labels.fs}</span> <b data-fs-readout>fs = 8.0 × f</b></span>
      <input type="range" min="1.2" max="16" step="0.1" value="8" data-fs />
    </label>
    <label class="adc-ctl">
      <span class="adc-ctl-label"><span>{labels.bits}</span> <b data-bits-readout>N = 4 bit · 16 levels</b></span>
      <input type="range" min="1" max="8" step="1" value="4" data-bits />
    </label>
    <button type="button" class="btn adc-toggle" data-toggle>{labels.pause}</button>
  </div>

  <div class="adc-power">
    <span class="adc-ctl-label"><span>{labels.power}</span> <b data-power-readout></b></span>
    <div class="adc-power-bar">
      <div class="adc-power-fill" data-power-fill></div>
    </div>
    <span class="adc-power-hint">{labels.powerHint}</span>
  </div>
</div>

<style>
  .adc-panel { padding: 0; overflow: hidden; margin-top: 20px; }

  .adc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    border-bottom: 1px solid var(--line);
    background: var(--blue-soft);
  }
  .adc-title {
    font-family: var(--mono);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .adc-status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .adc-led {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
  }
  .adc-led.off { background: var(--line); box-shadow: none; }
  @media (prefers-reduced-motion: no-preference) {
    .adc-led:not(.off) { animation: adc-blink 2s steps(1) infinite; }
    @keyframes adc-blink { 50% { opacity: 0.45; } }
  }

  .adc-intro {
    margin: 0;
    padding: 12px 16px;
    border-bottom: 1px dashed var(--line);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .adc-canvas {
    display: block;
    width: 100%;
    height: 240px;
    background: transparent;
  }

  .adc-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 18px;
    align-items: center;
    padding: 8px 16px;
    border-top: 1px dashed var(--line);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .adc-legend .sw {
    display: inline-block;
    width: 14px; height: 3px;
    margin-right: 6px;
    vertical-align: middle;
  }
  .sw-analog { background: var(--accent); }
  .sw-sample { height: 7px; width: 7px; border-radius: 50%; background: var(--ink); }
  .sw-digital { background: var(--blue); }
  .adc-alias {
    color: var(--accent);
    font-weight: 600;
    margin-left: auto;
  }

  .adc-controls {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 14px 22px;
    align-items: end;
    padding: 12px 16px 14px;
    border-top: 1px solid var(--line);
    background: var(--card);
  }
  .adc-ctl { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .adc-ctl-label {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2px 10px;
    min-width: 0;
  }
  .adc-ctl-label b { color: var(--accent); font-weight: 600; white-space: nowrap; }
  .adc-ctl input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    cursor: pointer;
  }
  .adc-toggle { padding: 5px 12px; font-size: 0.7rem; }

  .adc-power {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 12px 16px 16px;
    border-top: 1px dashed var(--line);
    background: var(--card);
  }
  .adc-power-bar {
    height: 12px;
    border: 1px solid var(--line);
    background: var(--paper);
    overflow: hidden;
  }
  .adc-power-fill {
    height: 100%;
    width: 4%;
    background: linear-gradient(90deg, var(--blue), var(--accent));
    transition: width 220ms ease;
  }
  .adc-power-hint {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .adc-controls { grid-template-columns: 1fr; }
    .adc-toggle { justify-self: end; }
  }
</style>

<script is:inline>
(() => {
  const root = document.querySelector("[data-adc]");
  if (!root) return;

  const canvas = root.querySelector("[data-canvas]");
  const ctx = canvas.getContext("2d");
  const fsInput = root.querySelector("[data-fs]");
  const bitsInput = root.querySelector("[data-bits]");
  const fsReadout = root.querySelector("[data-fs-readout]");
  const bitsReadout = root.querySelector("[data-bits-readout]");
  const powerReadout = root.querySelector("[data-power-readout]");
  const powerFill = root.querySelector("[data-power-fill]");
  const aliasWarn = root.querySelector("[data-alias]");
  const toggleBtn = root.querySelector("[data-toggle]");
  const led = root.querySelector("[data-led]");
  const statusEl = root.querySelector("[data-status]");

  const L = {
    pause: toggleBtn.textContent,
    run: root.dataset.runLabel,
    running: statusEl.textContent,
    paused: root.dataset.pausedLabel,
    comparators: root.dataset.compLabel,
    comparator: root.dataset.compSingular,
    powerUnit: root.dataset.powerUnit,
  };

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let running = !reduced;
  let phase = 0;
  let lastTs = 0;
  let colors = {};

  const CYCLES = 2.5; // signal cycles visible in the window

  // ideal flash ADC power model: (2^N − 1) comparators, each running at fs
  const FS_MIN = 1.2, FS_MAX = 16, BITS_MAX = 8;
  const P_MIN = (Math.pow(2, 1) - 1) * FS_MIN;
  const P_MAX = (Math.pow(2, BITS_MAX) - 1) * FS_MAX;

  function readColors() {
    const s = getComputedStyle(document.documentElement);
    colors = {
      accent: s.getPropertyValue("--accent").trim(),
      blue: s.getPropertyValue("--blue").trim(),
      ink: s.getPropertyValue("--ink").trim(),
      muted: s.getPropertyValue("--muted").trim(),
      line: s.getPropertyValue("--line").trim(),
    };
  }
  readColors();
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
    readColors();
    draw();
  });

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    draw();
  }
  new ResizeObserver(resize).observe(canvas);

  const signal = (cyc) => Math.sin(2 * Math.PI * (cyc + phase));

  function quantize(x, bits) {
    const levels = Math.pow(2, bits);
    const clamped = Math.max(-1, Math.min(1, x));
    return (Math.round(((clamped + 1) / 2) * (levels - 1)) / (levels - 1)) * 2 - 1;
  }

  function draw() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    if (!w || !h) return;
    ctx.clearRect(0, 0, w, h);

    const pad = 14;
    const midY = h / 2;
    const amp = (h - pad * 2) / 2;
    const yOf = (v) => midY - v * amp;

    const fsRatio = parseFloat(fsInput.value); // samples per signal cycle
    const bits = parseInt(bitsInput.value, 10);

    // quantization level gridlines (only when readable)
    const levels = Math.pow(2, bits);
    ctx.strokeStyle = colors.line;
    ctx.lineWidth = 0.5;
    ctx.globalAlpha = 0.55;
    if (levels <= 32) {
      for (let i = 0; i < levels; i++) {
        const v = (i / (levels - 1)) * 2 - 1;
        ctx.beginPath();
        ctx.moveTo(0, yOf(v));
        ctx.lineTo(w, yOf(v));
        ctx.stroke();
      }
    }
    ctx.globalAlpha = 1;

    // midline
    ctx.strokeStyle = colors.muted;
    ctx.globalAlpha = 0.4;
    ctx.setLineDash([3, 5]);
    ctx.beginPath();
    ctx.moveTo(0, midY);
    ctx.lineTo(w, midY);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.globalAlpha = 1;

    // analog input (copper)
    ctx.strokeStyle = colors.accent;
    ctx.lineWidth = 1.8;
    ctx.beginPath();
    for (let px = 0; px <= w; px++) {
      const y = yOf(signal((px / w) * CYCLES));
      px === 0 ? ctx.moveTo(px, y) : ctx.lineTo(px, y);
    }
    ctx.stroke();

    // samples + zero-order-hold staircase (ink blue)
    const totalSamples = Math.floor(CYCLES * fsRatio);
    const sampleXs = [];
    const sampleQs = [];
    for (let k = 0; k <= totalSamples; k++) {
      const cyc = k / fsRatio;
      if (cyc > CYCLES) break;
      sampleXs.push((cyc / CYCLES) * w);
      sampleQs.push(quantize(signal(cyc), bits));
    }

    ctx.strokeStyle = colors.blue;
    ctx.lineWidth = 1.8;
    ctx.beginPath();
    for (let i = 0; i < sampleXs.length; i++) {
      const x = sampleXs[i];
      const y = yOf(sampleQs[i]);
      if (i === 0) ctx.moveTo(x, y);
      else {
        ctx.lineTo(x, yOf(sampleQs[i - 1]));
        ctx.lineTo(x, y);
      }
    }
    const lastX = sampleXs[sampleXs.length - 1];
    if (lastX < w) ctx.lineTo(w, yOf(sampleQs[sampleQs.length - 1]));
    ctx.stroke();

    // sample dots
    ctx.fillStyle = colors.ink;
    for (let i = 0; i < sampleXs.length; i++) {
      ctx.beginPath();
      ctx.arc(sampleXs[i], yOf(sampleQs[i]), 2.6, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function updateReadouts() {
    const fsRatio = parseFloat(fsInput.value);
    const bits = parseInt(bitsInput.value, 10);
    fsReadout.textContent = `fs = ${fsRatio.toFixed(1)} × f`;
    bitsReadout.textContent = `N = ${bits} bit · ${Math.pow(2, bits)} levels`;
    aliasWarn.hidden = fsRatio >= 2;

    const comps = Math.pow(2, bits) - 1;
    const power = comps * fsRatio;
    const rel = power / P_MIN;
    const relText = rel >= 100 ? Math.round(rel).toLocaleString() : rel.toFixed(1);
    powerReadout.textContent = `${comps} ${comps === 1 ? L.comparator : L.comparators} · ${relText}${L.powerUnit}`;
    // log scale: 1 comparator @ slowest → full 2^8−1 @ fastest
    const frac = Math.log(power / P_MIN) / Math.log(P_MAX / P_MIN);
    powerFill.style.width = `${4 + 96 * Math.max(0, Math.min(1, frac))}%`;
  }

  function frame(ts) {
    if (!running) return;
    if (lastTs) phase += (ts - lastTs) * 0.00012; // slow drift
    lastTs = ts;
    draw();
    requestAnimationFrame(frame);
  }

  function setRunning(on) {
    running = on;
    led.classList.toggle("off", !on);
    statusEl.textContent = on ? L.running : L.paused;
    toggleBtn.textContent = on ? L.pause : L.run;
    if (on) {
      lastTs = 0;
      requestAnimationFrame(frame);
    }
  }

  fsInput.addEventListener("input", () => { updateReadouts(); draw(); });
  bitsInput.addEventListener("input", () => { updateReadouts(); draw(); });
  toggleBtn.addEventListener("click", () => setRunning(!running));

  updateReadouts();
  resize();
  setRunning(running);
  if (!running) {
    // reduced motion: render one static frame, controls still work
    led.classList.add("off");
    statusEl.textContent = L.paused;
    toggleBtn.textContent = L.run;
    draw();
  }
})();
</script>
